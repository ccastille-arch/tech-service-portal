<%- include('partials/head', { title: title }) %>
<body>
<div class="app-layout">
  <%- include('partials/nav') %>
  <div class="main-content">
    <div class="top-bar">
      <button class="hamburger" onclick="toggleSidebar()">☰</button>
      <span class="top-bar-title">What's New</span>
    </div>
    <div class="page-content">
      <%- include('partials/flash') %>

      <div style="max-width:720px;margin:0 auto;">
        <div style="text-align:center;margin-bottom:2rem;">
          <div style="font-family:var(--font-display);font-size:2rem;letter-spacing:.08em;color:var(--text-bright);">WHAT'S NEW</div>
          <div style="font-size:.85rem;color:var(--text-muted);margin-top:.3rem;">Latest features and improvements to the Tech Service Portal</div>
          <% if (user && user.role === 'admin') { %>
          <a href="/admin?tab=changelog" class="btn btn-ghost btn-sm" style="margin-top:.75rem;">⚙ Manage Entries</a>
          <% } %>
        </div>

        <% if (entries.length === 0) { %>
        <div class="empty-state"><span class="empty-icon">✨</span><h3>Nothing yet</h3><p>Updates will appear here as new features are released.</p></div>
        <% } %>

        <%
          const typeConfig = {
            new:         { label: 'New',         color: 'var(--success)',   bg: 'rgba(0,212,160,.1)',   icon: '🚀' },
            feature:     { label: 'Feature',     color: 'var(--secondary)', bg: 'rgba(0,200,232,.08)',  icon: '✨' },
            improvement: { label: 'Improvement', color: 'var(--primary)',   bg: 'rgba(255,107,0,.08)',  icon: '⚡' },
            fix:         { label: 'Fix',         color: 'var(--warning)',   bg: 'rgba(255,214,10,.08)', icon: '🔧' },
          };
        %>

        <div style="display:flex;flex-direction:column;gap:1rem;">
          <% for (const e of entries) { %>
          <% const cfg = typeConfig[e.type] || typeConfig.feature; %>
          <div style="background:var(--bg-surface);border:1px solid var(--border);border-left:3px solid <%= cfg.color %>;border-radius:8px;padding:1.1rem 1.25rem;">
            <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.5rem;flex-wrap:wrap;">
              <span style="font-size:1.1rem;"><%= cfg.icon %></span>
              <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:<%= cfg.color %>;background:<%= cfg.bg %>;padding:.15rem .6rem;border-radius:10px;"><%= cfg.label %></span>
              <% if (e.version) { %><span style="font-size:.7rem;color:var(--text-muted);font-family:monospace;">v<%= e.version %></span><% } %>
              <span style="font-size:.7rem;color:var(--text-muted);margin-left:auto;"><%= new Date(e.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) %></span>
            </div>
            <div style="font-weight:700;font-size:1rem;color:var(--text-bright);margin-bottom:.35rem;"><%= e.title %></div>
            <div style="font-size:.85rem;color:var(--text-muted);line-height:1.6;"><%= e.description %></div>
          </div>
          <% } %>
        </div>

        <div style="text-align:center;margin-top:2rem;padding-top:1.5rem;border-top:1px solid var(--border);">
          <a href="/feature-requests" class="btn btn-ghost">💡 Have an idea? Submit a Feature Request</a>
        </div>
      </div>

    </div>
  </div>
</div>
<script src="/public/js/app.js"></script>
</body>
</html>
