<aside class="sidebar" id="sidebar">
  <div class="sidebar-logo">
    <span class="logo-text">TECH SERVICE</span>
    <span class="logo-sub">Work Order Portal</span>
  </div>
  <nav class="sidebar-nav">
    <a href="/dashboard" class="nav-link <%= locals.title && title.includes('Dashboard') ? 'active' : '' %>">
      <span class="nav-icon">📊</span> Dashboard
    </a>
    <a href="/tickets/new" class="nav-link">
      <span class="nav-icon">➕</span> New Work Order
    </a>
    <a href="/tickets" class="nav-link <%= locals.title && title.includes('Work Order') ? 'active' : '' %>">
      <span class="nav-icon">📋</span> All Work Orders
    </a>
    <a href="/fleet" class="nav-link <%= locals.title && title.includes('Fleet') ? 'active' : '' %>">
      <span class="nav-icon">⚙</span> Fleet Monitor
    </a>
    <a href="/notifications" class="nav-link <%= locals.title && title.includes('Notification') ? 'active' : '' %>">
      <span class="nav-icon">🔔</span> Notifications
      <% if (unreadCount > 0) { %><span class="nav-badge"><%= unreadCount %></span><% } %>
    </a>
    <a href="/whats-new" class="nav-link <%= locals.title && title.includes("What") ? 'active' : '' %>">
      <span class="nav-icon">✨</span> What's New
    </a>
    <a href="/feature-requests" class="nav-link <%= locals.title && title.includes('Feature') ? 'active' : '' %>">
      <span class="nav-icon">💡</span> Feature Requests
    </a>
    <% if (user && user.role === 'admin') { %>
    <span class="nav-section-label">Admin</span>
    <a href="/admin" class="nav-link <%= locals.title && title.includes('Admin Panel') ? 'active' : '' %>">
      <span class="nav-icon">🛡</span> Admin Panel
    </a>
    <a href="/nexus/calls" class="nav-link <%= locals.title && title.includes('Call Operations') ? 'active' : '' %>">
      <span class="nav-icon">📞</span> Calls
    </a>
    <a href="/nexus/scheduler" class="nav-link <%= locals.title && title.includes('Scheduler') ? 'active' : '' %>">
      <span class="nav-icon">📅</span> Scheduler
    </a>
    <a href="/nexus/escalation" class="nav-link <%= locals.title && title.includes('Escalation') ? 'active' : '' %>">
      <span class="nav-icon">🚨</span> Escalation
    </a>
    <a href="/reports" class="nav-link <%= locals.title && title.includes('Report') ? 'active' : '' %>">
      <span class="nav-icon">📈</span> Reports & Analytics
    </a>
    <a href="/integrations" class="nav-link <%= locals.title && title.includes('Integration') ? 'active' : '' %>">
      <span class="nav-icon">🔗</span> Integrations
    </a>
    <a href="/calls" class="nav-link <%= locals.title && title.includes('Call') ? 'active' : '' %>">
      <span class="nav-icon">📞</span> Call Log
    </a>
    <% } %>
  </nav>
  <div class="sidebar-footer">
    <div class="user-name"><%= user ? user.name : '' %></div>
    <div class="user-role"><%= user ? user.role : '' %></div>
    <a href="/logout" class="btn btn-ghost btn-sm mt-1" style="width:100%;justify-content:center;">Log Out</a>
  </div>
</aside>
<div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
