<%- include('partials/head', { title: title }) %>
<body>
<div class="app-layout">
  <%- include('partials/nav') %>
  <div class="main-content">
    <div class="top-bar">
      <button class="hamburger" onclick="toggleSidebar()">☰</button>
      <span class="top-bar-title">Dashboard</span>
      <div class="top-bar-actions">
        <a href="/tickets/new" class="btn btn-primary btn-sm">+ New Ticket</a>
      </div>
    </div>
    <div class="page-content">
      <%- include('partials/flash') %>

      <!-- Stats Row -->
      <div class="stats-grid">
        <div class="stat-card secondary">
          <div class="stat-value"><%= stats.open %></div>
          <div class="stat-label">Open</div>
        </div>
        <div class="stat-card primary">
          <div class="stat-value"><%= stats.inProgress %></div>
          <div class="stat-label">In Progress</div>
        </div>
        <div class="stat-card warning">
          <div class="stat-value"><%= stats.onHold %></div>
          <div class="stat-label">On Hold</div>
        </div>
        <div class="stat-card danger">
          <div class="stat-value"><%= stats.overdue %></div>
          <div class="stat-label">Overdue</div>
        </div>
        <div class="stat-card success">
          <div class="stat-value"><%= stats.completedToday %></div>
          <div class="stat-label">Closed Today</div>
        </div>
        <div class="stat-card">
          <div class="stat-value"><%= slaCompliance %>%</div>
          <div class="stat-label">SLA Compliance</div>
        </div>
      </div>

      <!-- Priority + Tech Breakdown -->
      <div class="d-flex gap-2 flex-wrap mb-3">
        <div class="card" style="flex:1;min-width:280px;">
          <div class="card-header">
            <div class="card-title">Priority Breakdown</div>
          </div>
          <div class="priority-breakdown">
            <% for (const [p, cls] of [['P1','p1'],['P2','p2'],['P3','p3'],['P4','p4']]) { %>
            <div class="priority-item">
              <div>
                <div class="priority-count <%= cls %>-count"><%= priorityCounts[p] %></div>
                <div class="priority-label"><%= p %></div>
              </div>
            </div>
            <% } %>
          </div>
        </div>
        <div class="card" style="flex:1;min-width:280px;">
          <div class="card-header">
            <div class="card-title">Assigned Tickets</div>
          </div>
          <% for (const tech of techBreakdown) { %>
          <div class="d-flex justify-between align-center" style="padding:.4rem 0;border-bottom:1px solid var(--border);">
            <span style="font-weight:600;"><%= tech.name %></span>
            <span class="badge badge-p3"><%= tech.cnt %> open</span>
          </div>
          <% } %>
        </div>
      </div>

      <!-- My Tickets (tech view) -->
      <% if (user.role === 'tech' && myTickets.length > 0) { %>
      <div class="card mb-3">
        <div class="card-header">
          <div class="card-title">My Open Tickets</div>
          <a href="/tickets?assigned=<%= user.id %>" class="btn btn-ghost btn-sm">View All</a>
        </div>
        <div class="table-container">
          <table class="table">
            <thead><tr>
              <th>Ticket</th><th>Title</th><th>Priority</th><th>Status</th><th>SLA</th><th>Due</th>
            </tr></thead>
            <tbody>
              <% for (const t of myTickets) { %>
              <tr>
                <td><a href="/tickets/<%= t.id %>" class="ticket-link"><%= t.ticket_number %></a></td>
                <td><%= t.title %></td>
                <td><span class="badge badge-<%= t.priority.toLowerCase() %>"><%= t.priority %></span></td>
                <td><span class="badge badge-<%= t.status %>"><%= t.status %></span></td>
                <td><span class="badge badge-sla-<%= t.slaStatus %>"><%= t.slaStatus %></span></td>
                <td style="color:var(--text-muted);font-size:.85rem;"><%= t.due_date ? new Date(t.due_date).toLocaleDateString() : '—' %></td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- Recent Tickets (admin) -->
      <% if (user.role === 'admin' && recentTickets.length > 0) { %>
      <div class="card mb-3">
        <div class="card-header">
          <div class="card-title">Recent Work Orders</div>
          <a href="/tickets" class="btn btn-ghost btn-sm">View All</a>
        </div>
        <div class="table-container">
          <table class="table">
            <thead><tr>
              <th>Ticket</th><th>Title</th><th>Priority</th><th>Status</th><th>Assigned</th><th>SLA</th>
            </tr></thead>
            <tbody>
              <% for (const t of recentTickets) { %>
              <tr>
                <td><a href="/tickets/<%= t.id %>" class="ticket-link"><%= t.ticket_number %></a></td>
                <td><%= t.title %></td>
                <td><span class="badge badge-<%= t.priority.toLowerCase() %>"><%= t.priority %></span></td>
                <td><span class="badge badge-<%= t.status %>"><%= t.status %></span></td>
                <td style="font-size:.85rem;"><%= t.assigned_name || '<span style="color:var(--text-muted)">Unassigned</span>' %></td>
                <td><span class="badge badge-sla-<%= t.slaStatus %>"><%= t.slaStatus %></span></td>
              </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
      <% } %>

      <!-- Integrations Live Status -->
      <div class="card mb-3">
        <div class="card-header">
          <div class="card-title">🔌 Integrations — Live Data</div>
          <button class="btn btn-ghost btn-sm" onclick="loadIntegrations()">⟳ Refresh</button>
        </div>
        <div id="integrations-grid" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:12px;padding:4px 0;">
          <!-- Enbase -->
          <div class="stat-card" id="enbase-card" style="flex-direction:column;align-items:flex-start;gap:6px;">
            <div style="display:flex;align-items:center;justify-content:space-between;width:100%">
              <span style="font-weight:700;font-size:.9rem;">🛢 Detechtion Enbase</span>
              <span id="enbase-badge" class="badge" style="font-size:.7rem;">loading…</span>
            </div>
            <div id="enbase-summary" style="font-size:.82rem;color:var(--text-muted);line-height:1.5;">Connecting…</div>
            <div id="enbase-alarms" style="font-size:.78rem;"></div>
          </div>
          <!-- MLink -->
          <div class="stat-card" id="mlink-card" style="flex-direction:column;align-items:flex-start;gap:6px;">
            <div style="display:flex;align-items:center;justify-content:space-between;width:100%">
              <span style="font-weight:700;font-size:.9rem;">⚙️ FW Murphy MLink</span>
              <span id="mlink-badge" class="badge" style="font-size:.7rem;">loading…</span>
            </div>
            <div id="mlink-summary" style="font-size:.82rem;color:var(--text-muted);line-height:1.5;">Connecting…</div>
            <div id="mlink-readings" style="font-size:.78rem;"></div>
          </div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="card">
        <div class="card-header">
          <div class="card-title">Recent Activity</div>
        </div>
        <% if (activity.length === 0) { %>
        <div class="empty-state" style="padding:1.5rem;">
          <p>No activity yet.</p>
        </div>
        <% } else { %>
        <div class="timeline">
          <% for (const a of activity) { %>
          <div class="timeline-item">
            <div class="timeline-dot <%= a.field_changed === 'status' ? 'primary' : '' %>"></div>
            <div class="timeline-time"><%= new Date(a.changed_at).toLocaleString() %></div>
            <div class="timeline-text">
              <strong><%= a.actor_name %></strong> changed
              <a href="/tickets/<%= a.ticket_id %>" style="color:var(--secondary);"><%= a.ticket_number %></a>
              <em><%= a.field_changed %></em>:
              <% if (a.old_value) { %><span style="color:var(--text-muted)"><%= a.old_value %></span> →<% } %>
              <span style="color:var(--text-bright);font-weight:600;"><%= a.new_value %></span>
            </div>
          </div>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script src="/public/js/app.js"></script>
<script>
function esc(s) { return String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }

async function loadEnbase() {
  const badge = document.getElementById('enbase-badge');
  const summary = document.getElementById('enbase-summary');
  const alarmEl = document.getElementById('enbase-alarms');
  try {
    const r = await fetch('/integrations/live/enbase?type=alarms');
    const d = await r.json();
    if (d.ok) {
      badge.textContent = d.count + ' alarms';
      badge.className = 'badge ' + (d.count > 0 ? 'badge-p2' : 'badge-p4');
      const active = d.records.filter(a => /active|open|new/i.test(String(a.status||a.state||'')));
      summary.textContent = `${d.count} alarm records · ${active.length} active`;
      if (d.records.length) {
        alarmEl.innerHTML = d.records.slice(0,3).map(a =>
          `<div style="padding:3px 0;border-bottom:1px solid var(--border)">
            <span style="color:${/crit|high|1/i.test(String(a.severity||a.priority||''))? 'var(--danger)':'var(--warning)'}">●</span>
            ${esc(a.message||a.alarmText||a.description||a.name||'Alarm')}
            <span style="color:var(--text-muted);float:right">${esc(a.assetName||a.asset||'')}</span>
          </div>`
        ).join('');
      }
    } else {
      badge.textContent = 'error'; badge.className = 'badge badge-p1';
      summary.textContent = d.error || 'Connection failed';
    }
  } catch(e) {
    document.getElementById('enbase-badge').textContent = 'offline';
    document.getElementById('enbase-summary').textContent = e.message;
  }
}

async function loadMlink() {
  const badge = document.getElementById('mlink-badge');
  const summary = document.getElementById('mlink-summary');
  const readEl = document.getElementById('mlink-readings');
  try {
    const r = await fetch('/integrations/live/mlink?type=telemetry');
    const d = await r.json();
    if (d.ok) {
      badge.textContent = d.count + ' readings';
      badge.className = 'badge badge-p4';
      summary.textContent = `${d.count} data points across ${[...new Set(d.records.map(r=>r._deviceId).filter(Boolean))].length || '?'} devices`;
      if (d.records.length) {
        const byDevice = {};
        d.records.forEach(r => {
          const lbl = r._deviceLabel || r._deviceId || 'Unknown';
          if (!byDevice[lbl]) byDevice[lbl] = [];
          byDevice[lbl].push(r);
        });
        readEl.innerHTML = Object.entries(byDevice).slice(0,3).map(([lbl, rows]) => {
          const row = rows[0];
          const val = row.value ?? row.reading ?? row.currentValue ?? '—';
          const unit = row.unit ?? row.uom ?? '';
          return `<div style="padding:3px 0;border-bottom:1px solid var(--border)">
            <strong>${esc(lbl)}</strong>
            <span style="color:var(--text-muted);float:right">${esc(val)} ${esc(unit)}</span>
          </div>`;
        }).join('');
      }
    } else {
      badge.textContent = 'error'; badge.className = 'badge badge-p1';
      summary.textContent = d.error || 'Connection failed';
    }
  } catch(e) {
    document.getElementById('mlink-badge').textContent = 'offline';
    document.getElementById('mlink-summary').textContent = e.message;
  }
}

function loadIntegrations() { loadEnbase(); loadMlink(); }
loadIntegrations();
</script>
</body>
</html>
