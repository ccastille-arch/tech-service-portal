<%- include('partials/head', { title: title || 'Error' }) %>
<body>
<% if (user) { %>
<div class="app-layout">
  <%- include('partials/nav') %>
  <div class="main-content">
    <div class="top-bar">
      <button class="hamburger" onclick="toggleSidebar()">☰</button>
      <span class="top-bar-title">Error</span>
    </div>
    <div class="page-content">
      <div class="empty-state">
        <span class="empty-icon">⚠</span>
        <h3><%= title || 'Error' %></h3>
        <p><%= message %></p>
        <a href="/dashboard" class="btn btn-primary mt-2">Return to Dashboard</a>
      </div>
    </div>
  </div>
</div>
<% } else { %>
<div class="login-page">
  <div class="login-bg"></div>
  <div class="login-card" style="text-align:center;">
    <p style="font-size:3rem;">⚠</p>
    <h2 style="font-family:var(--font-display);color:var(--danger);letter-spacing:.06em;margin:.5rem 0;"><%= title || 'Error' %></h2>
    <p style="color:var(--text-muted);margin-bottom:1.5rem;"><%= message %></p>
    <a href="/login" class="btn btn-primary">Return to Login</a>
  </div>
</div>
<% } %>
<script src="/public/js/app.js"></script>
</body>
</html>
